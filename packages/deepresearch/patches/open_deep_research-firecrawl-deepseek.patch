+FIRECRAWL_SEARCH_DESCRIPTION = (
+    "A web search tool backed by Firecrawl. It returns search results with scraped "
+    "markdown content when available, including source URLs for citation."
+)
+
+@tool(description=FIRECRAWL_SEARCH_DESCRIPTION)
+async def firecrawl_search(
+    queries: List[str],
+    max_results: Annotated[int, InjectedToolArg] = 5,
+    config: RunnableConfig = None,
+) -> str:
+    """Fetch web search results from Firecrawl.
+
+    Args:
+        queries: List of search queries to execute.
+        max_results: Maximum number of results to return per query.
+        config: Runtime configuration.
+
+    Returns:
+        Formatted string containing search results and scraped markdown snippets.
+    """
+    try:
+        from firecrawl import FirecrawlApp
+    except ImportError:
+        return "Error: firecrawl-py is not installed."
+
+    api_key = os.environ.get("FIRECRAWL_API_KEY")
+    if not api_key:
+        return "Error: FIRECRAWL_API_KEY is not set."
+
+    client = FirecrawlApp(api_key=api_key)
+
+    async def run_search(query: str):
+        return await asyncio.to_thread(
+            client.search,
+            query,
+            limit=max_results,
+            scrape_options={"formats": ["markdown"]},
+        )
+
+    search_results = await asyncio.gather(*[run_search(query) for query in queries])
+
+    formatted_output = "Search results:\n\n"
+    source_index = 1
+    for query, response in zip(queries, search_results):
+        web_results = getattr(response, "web", None) or []
+        formatted_output += f"Query: {query}\n"
+        if not web_results:
+            formatted_output += "No results found.\n\n"
+            continue
+
+        for item in web_results:
+            metadata = getattr(item, "metadata", None)
+            title = getattr(metadata, "title", None) or getattr(item, "title", None) or "Untitled"
+            url = getattr(metadata, "url", None) or getattr(metadata, "source_url", None) or getattr(item, "url", None) or ""
+            description = getattr(metadata, "description", None) or getattr(item, "description", None) or ""
+            markdown = getattr(item, "markdown", None) or ""
+            content = markdown or description
+            formatted_output += f"\n--- SOURCE {source_index}: {title} ---\n"
+            formatted_output += f"URL: {url}\n\n"
+            formatted_output += f"CONTENT:\n{content[:8000]}\n\n"
+            formatted_output += "-" * 80 + "\n"
+            source_index += 1
+
+    return formatted_output
+
